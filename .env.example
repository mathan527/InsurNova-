# Application
NODE_ENV=development
PORT=3000
LOG_LEVEL=info

# Supabase Database (REQUIRED - Get from https://supabase.com/dashboard)
SUPABASE_URL=your_supabase_project_url
SUPABASE_SERVICE_KEY=your_supabase_service_role_key

# Redis (for queue management)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ML API
ML_API_URL=http://localhost:8000
ML_API_TIMEOUT=30000

# External APIs (Event Data)
WEATHER_API_KEY=your_weather_api_key
WEATHER_API_URL=https://api.weatherapi.com/v1
POLLUTION_API_KEY=your_pollution_api_key
POLLUTION_API_URL=https://api.openaq.org/v2

# Wallet/Payment Gateway
PAYMENT_GATEWAY_URL=https://payment-provider.com/api
PAYMENT_API_KEY=your_payment_key
PAYMENT_SECRET=your_payment_secret

# Notification Services
SENDGRID_API_KEY=your_sendgrid_key
TWILIO_ACCOUNT_SID=your_twilio_sid
TWILIO_AUTH_TOKEN=your_twilio_token
TWILIO_PHONE_NUMBER=+1234567890

# Agent Configuration
RISK_THRESHOLD=0.7
FRAUD_THRESHOLD=0.8
CHURN_THRESHOLD=0.6
MIN_PAYOUT_AMOUNT=10
MAX_PAYOUT_AMOUNT=10000

# Feature Flags
ENABLE_FRAUD_CHECK=true
ENABLE_CHURN_PREDICTION=true
ENABLE_EXPLANATION=true
