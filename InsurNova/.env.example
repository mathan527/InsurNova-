VITE_API_URL=http://localhost:5000
VITE_ML_API_URL=http://localhost:8000
VITE_RAZORPAY_KEY_ID=rzp_test_SdL92ZDiCcokYu
VITE_SUPABASE_URL=https://gtniwhmwrevmfgzuqdnr.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# 🚀 BACKEND (Node.js)
# Copy these to backend/.env
PORT=5000
MONGO_URI=mongodb://localhost:27017/insurnova
JWT_SECRET=your_super_secret_jwt_key_here
RAZORPAY_KEY_ID=rzp_test_SdL92ZDiCcokYu
RAZORPAY_KEY_SECRET=your_razorpay_secret

# 🤖 ML SERVICE (FastAPI)
# Copy these to ml/.env
ML_PORT=8000
ML_DEBUG=True

# 🛠️ AGENT CONFIGURATION
RISK_THRESHOLD=0.7
FRAUD_THRESHOLD=0.8
CHURN_THRESHOLD=0.6
ENABLE_GPS_FRAUD_SCAN=true

# 📧 NOTIFICATIONS (Optional)
SENDGRID_API_KEY=your_sendgrid_key
TWILIO_ACCOUNT_SID=your_twilio_sid
TWILIO_AUTH_TOKEN=your_twilio_token
